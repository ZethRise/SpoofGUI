<Page
    x:Class="SpoofGUI.GUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource SurfaceBase}">

    <ScrollViewer>
        <Grid Padding="32,32,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="Settings" Style="{StaticResource TextCaption}" />
                <TextBlock Text="app preferences" Style="{StaticResource TextDisplay}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,32,0,0" Spacing="12">
                <TextBlock Text="Repository" Style="{StaticResource TextH2}" />
                <StackPanel Spacing="2">
                    <TextBlock Text="ZethRise/SpoofGUI" Style="{StaticResource TextBody}" />
                    <HyperlinkButton Content="https://github.com/ZethRise/SpoofGUI"
                                     NavigateUri="https://github.com/ZethRise/SpoofGUI"
                                     Padding="0" />
                    <TextBlock Text="GUI fork for SNI-Spoofing on Windows."
                               Style="{StaticResource TextBodyMuted}"
                               MaxWidth="560" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,32,0,0" Spacing="12">
                <TextBlock Text="Updates" Style="{StaticResource TextH2}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock x:Name="UpdateVersion" Text="installed: 0.1.0" Style="{StaticResource TextMono}" />
                        <TextBlock x:Name="UpdateLastCheck" Text="never checked" Style="{StaticResource TextCaption}" />
                        <HyperlinkButton Content="update channel: ZethRise/SpoofGUI"
                                         NavigateUri="https://github.com/ZethRise/SpoofGUI/releases"
                                         Padding="0" />
                        <HyperlinkButton x:Name="UpdateReleaseLink"
                                         Content="open release"
                                         NavigateUri="https://github.com/ZethRise/SpoofGUI/releases"
                                         Visibility="Collapsed"
                                         Padding="0" />
                    </StackPanel>
                    <Button x:Name="CheckUpdatesButton"
                            Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Top"
                            Click="OnCheckUpdates">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Sync" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="check for updates" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,32,0,0" Spacing="12">
                <TextBlock Text="Theme" Style="{StaticResource TextH2}" />
                <RadioButtons x:Name="ThemeChoice"
                              SelectionChanged="OnThemeChanged"
                              MaxColumns="2">
                    <x:String>dark</x:String>
                    <x:String>light</x:String>
                </RadioButtons>
                <TextBlock Text="Dark is the recommended default. Light is for bright rooms only; the accent palette is tuned for dark surfaces."
                           Style="{StaticResource TextCaption}"
                           MaxWidth="560" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
